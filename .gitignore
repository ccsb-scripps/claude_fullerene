# Python environment
.venv/
__pycache__/
*.pyc

# Third-party programs -- built/obtained locally (see README.txt for sources):
#   instant-meshes : github.com/wjakob/instant-meshes  (field-aligned remesher)
#   fullerene      : Schwerdtfeger/Wirz/Avery, Program Fullerene v4.5,
#                    J. Comput. Chem. 34 (2013) 1508  (canonical RSPI)
instant-meshes/
fullerene/

# Backups & scratch
*.bak
*.bak2

# Generated artifacts / outputs (all regenerated by run_all.sh from mesh4a.stl)
*.xyz
*.npz
*.npy
*.csv
*.ply
*.obj
*.inp
*_edges.txt
*.pdb
*.pdb1
*.cif
*.mmcif

# Fetched capsomer templates (RCSB 3H47, 3P05) + large atomic-capsid outputs (>100MB)
capsomer_templates/

# capsid_models/ : DO commit the compact per-mesh transforms JSON + co-registered
# surface OBJs + assembly mmCIFs (all small); skip the build/areafit logs.
!capsid_models/*.obj
!capsid_models/*_assembly.cif
capsid_models/*.log

# macOS
.DS_Store

# Blender movie setups + rendered movies (large binaries; regenerate via blender_load_set.build_movie)
*.blend
*.blend1
*.mp4
